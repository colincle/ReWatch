{
	"configurations": [
		{
			"name": "Mac",
			"includePath": [
				"${workspaceFolder}/**",
				"/usr/local/include",
				"/usr/local/opt/qt@5/include",
				"/usr/local/opt/qt@5/include/QtWidgets",
				"/usr/local/opt/qt@5/include/QtCore",
				"/usr/local/opt/qt@5/include/QtGui"
			],
			"defines": [
				"QT_WIDGETS_LIB",
				"QT_CORE_LIB",
				"QT_GUI_LIB"
			],
			"compilerPath": "/usr/bin/clang",
			"cStandard": "c17",
			"cppStandard": "c++20",
			"intelliSenseMode": "macos-clang-x64"
		}
	],
	"version": 4
}
